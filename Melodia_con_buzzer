const int buzzerPin = 4;

// Notas de la melodía (Hz)
int melody[] = {
  262, 294, 330, 349,
  392, 440, 494, 523
};

// Duración de cada nota (ms)
int noteDurations[] = {
  250, 250, 250, 250,
  250, 250, 250, 500
};

void setup() {
  pinMode(buzzerPin, OUTPUT);
}

void loop() {

  for (int i = 0; i < 8; i++) {
    tone(buzzerPin, melody[i]);
    delay(noteDurations[i]);

    noTone(buzzerPin);
    delay(50);
  }

  delay(1000); // Espera 1 segundo antes de repetir
}
